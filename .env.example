# Copy to .env and fill in. Never commit .env.

# Required in production (use a long random string, 32+ characters). Also used to sign admin cookies.
SESSION_SECRET=change-this-to-a-long-random-secret-in-production

# Admin login: generate with `npm run hash-password -- yourpassword`
ADMIN_PASSWORD_HASH=$2a$12$CjZbWbJNmxumUhx9ALU.z.tF1M2/xsHVHZeiHHznDttw3Qilp/asC

# Optional in development only (not used if ADMIN_PASSWORD_HASH is set)
# NODE_ENV=development
# ADMIN_PASSWORD=

# Server port (default 3000)
# PORT=3000

# --- Vercel only: persistent CMS (required for admin save/delete on Vercel) ---
# Vercel → Storage → Marketplace → “Redis” (Upstash). Create + link project; env is set automatically.
# Names are usually UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN.
# Some templates still expose KV_REST_API_URL / KV_REST_API_TOKEN — both are supported here.
# Local dev: leave unset to use data/blog.json and data/projects.json on disk.
