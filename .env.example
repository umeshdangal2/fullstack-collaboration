# Copy to .env and fill in. Never commit .env.

# Required in production (use a long random string, 32+ characters)
SESSION_SECRET=change-this-to-a-long-random-secret-in-production

# Admin login: generate with `npm run hash-password -- yourpassword`
ADMIN_PASSWORD_HASH=umeshd2

# Optional in development only (not used if ADMIN_PASSWORD_HASH is set)
# NODE_ENV=development
# ADMIN_PASSWORD=

# Server port (default 3000)
# PORT=3000
